<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Configuración del proyecto de investigación actual.
  Completar todos los campos ANTES de iniciar la primera sesión con el lead_researcher.
-->
<project_config>

  <metadata>
    <proyecto_slug>nombre-corto-sin-espacios</proyecto_slug>
    <titulo>Título completo del proyecto de investigación</titulo>
    <autor_humano>Nombre del investigador a cargo</autor_humano>
    <fecha_inicio>YYYY-MM-DD</fecha_inicio>
  </metadata>

  <tema>
    <campo_disciplinar>Ej: economía / sociología / ciencias de la computación / educación</campo_disciplinar>
    <tema_amplio>Ej: especialización productiva y crecimiento económico</tema_amplio>
    <recorte>Ej: empresas industriales argentinas, 2003-2019</recorte>
  </tema>

  <hipotesis_preliminar>
    <descripcion>
      Hipótesis tentativa que orienta la búsqueda inicial. Puede refinarse durante el proceso.
      NO debe sesgar al search_subagent: él debe buscar evidencia A FAVOR y EN CONTRA.
    </descripcion>
    <enunciado>Texto de la hipótesis preliminar.</enunciado>
  </hipotesis_preliminar>

  <alcance>
    <espacial>País / región / nivel de análisis</espacial>
    <temporal>Período YYYY-YYYY</temporal>
    <unidad_de_analisis>Firmas / individuos / países / textos / etc.</unidad_de_analisis>
  </alcance>

  <preferencias>
    <idioma_fuentes>es | en | mixto</idioma_fuentes>
    <formato_citas>APA-7</formato_citas>
    <profundidad_objetivo>piloto | revision_literatura | investigacion_completa</profundidad_objetivo>
    <persistir_en_notion>true | false</persistir_en_notion>
    <notion_database_id>...</notion_database_id>
  </preferencias>

  <restricciones>
    <restriccion>Ej: no usar fuentes anteriores a 1990 para evidencia empírica.</restriccion>
    <restriccion>Ej: priorizar revistas latinoamericanas indexadas.</restriccion>
  </restricciones>

  <conocimiento_previo_del_autor>
    <autores_clave_ya_identificados>
      <autor>Ej: Yoguel, G.</autor>
    </autores_clave_ya_identificados>
    <fuentes_ya_leidas>
      <fuente>Ej: Yoguel (2018), "Capacidades productivas..."</fuente>
    </fuentes_ya_leidas>
  </conocimiento_previo_del_autor>

</project_config>
